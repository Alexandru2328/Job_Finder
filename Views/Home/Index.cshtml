<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job_Finder</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5">
        <!-- Header -->
        <header class="text-center mb-5">
            <h1 class="display-4">Job_Finder</h1>
            <p class="lead">Un agregator de anunțuri online de pe platforme precum BestJobs, eJobs, LinkedIn și Indeed.</p>
        </header>

        <!-- Main Section -->
        <section class="row">
            <div class="col-md-6">
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">BestJobs</h5>
                        <p class="card-text">Căutare și aplicare la anunțuri pe BestJobs.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">eJobs</h5>
                        <p class="card-text">Căutare și aplicare la anunțuri pe eJobs.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">LinkedIn</h5>
                        <p class="card-text">Căutare și aplicare la anunțuri pe LinkedIn.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Indeed</h5>
                        <p class="card-text">Căutare și aplicare la anunțuri pe Indeed.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="text-center mt-5">
            <p>&copy; 2024 Job_Finder. Toate drepturile rezervate.</p>
        </footer>
    </div>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>
